POSTGRES_DB=kaizntree
POSTGRES_USER=kaizntree
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_SETTINGS_MODULE=kaizntree.settings.development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Optional: enables AI-powered document parsing at POST /api/v1/ai/parse-purchase-order/
# Without this key the endpoint returns 503 with a clear error message.
ANTHROPIC_API_KEY=

# ── E-commerce integrations (all optional — leave blank to disable) ─────────
# Shopify: webhook ingestion at POST /api/v1/integrations/shopify/webhook/
# Get SHOPIFY_WEBHOOK_SECRET from: Shopify Admin > Settings > Notifications > Webhooks
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# Amazon SP-API: order polling + inventory sync
# Credentials from: Seller Central > Apps & Services > Develop Apps
AMAZON_SELLER_ID=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_LWA_REFRESH_TOKEN=
AMAZON_AWS_ACCESS_KEY=
AMAZON_AWS_SECRET_KEY=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# ── ERP integrations (all optional — leave blank to disable) ─────────────────
# QuickBooks Online: sync confirmed POs as Bills, suppliers as Vendors
# Get credentials from: developer.intuit.com > My Apps
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_ENVIRONMENT=sandbox

# NetSuite: sync confirmed POs as VendorBills (TBA OAuth 1.0a)
# Credentials from: NetSuite Admin > Setup > Integration > Manage Integrations
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=
NETSUITE_SUBSIDIARY_ID=1
